{
    "name": "@convoai/auth-service",
    "version": "1.0.0",
    "private": true,
    "main": "dist/app.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "db:migrate": "pnpm prisma migrate dev",
        "db:generate": "pnpm prisma generate",
        "generate:proto": "protoc --proto_path=../../proto --ts_proto_out=src/generated/ --ts_proto_opt=esModuleInterop=true,outputServices=grpc-js,outputClientImpl=grpc-js ../../proto/auth.proto"
    },
    "dependencies": {
        "@bufbuild/protobuf": "^2.12.1",
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^11.2.0",
        "@fastify/jwt": "^10.1.0",
        "@fastify/redis": "^8.0.0",
        "@grpc/grpc-js": "^1.14.4",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "argon2": "^0.44.0",
        "fastify": "^5.8.5",
        "fastify-plugin": "^6.0.0",
        "ioredis": "^5.4.1",
        "pg": "^8.11.5",
        "pino-pretty": "^13.1.3",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/node": "^20.11.30",
        "@types/pg": "^8.11.5",
        "prisma": "^7.8.0",
        "ts-proto": "^2.11.8",
        "tsx": "^4.7.1",
        "typescript": "^5.4.3"
    }
}