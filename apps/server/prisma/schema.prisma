generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum PodcastStatus {
  DRAFT
  PROCESSING
  PUBLISHED
  FAILED
}

enum Visibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

model User {
  id       String @id @default(uuid())
  username String @unique
  email    String @unique

  firstName String
  lastName  String?

  passwordHash String

  role Role @default(USER)

  createdAt DateTime @default(now())

  sessions      Session[]
}

model Session {
  sessionId String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  refreshTokenHash String

  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([userId])
}

model Channel {
  id String @id @default(uuid())

  name String
  slug String @unique

  description String

  bannerUrl         String?
  profilePictureUrl String?

  subscriberCount Int @default(0)
  podcastCount    Int @default(0)

  createdAt DateTime @default(now())

  ownerId String
  // owner   User   @relation(fields: [ownerId], references: [id])

  // podcasts      Podcast[]
  // subscriptions ChannelSubscription[]

  @@index([ownerId])
  @@index([slug])
}

model ChannelSubscription {
  userId    String
  channelId String

  createdAt DateTime @default(now())

  // user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
  @@index([channelId])
  @@index([userId])
}

model Podcast {
  id String @id @default(uuid())

  title       String
  description String

  thumbnail String?
  audioUrl  String?

  duration Int?

  views     Int @default(0)
  upvotes   Int @default(0)
  downvotes Int @default(0)

  status     PodcastStatus @default(DRAFT)
  visibility Visibility    @default(PUBLIC)

  createdAt DateTime @default(now())

  channelId String
  // channel   Channel @relation(fields: [channelId], references: [id])

  @@index([channelId])
  @@index([createdAt])
  @@index([status])
}
model WatchHistory {
  id        String   @id @default(uuid())
  userId    String   
  podcastId String   
  
  watchedAt DateTime @default(now())
  progress  Int      @default(0) 

  @@index([userId])
  @@index([podcastId])
}
enum VoteType {
  UPVOTE
  DOWNVOTE
}

model PodcastVote {
  userId    String   
  podcastId String  
  type      VoteType

  createdAt DateTime @default(now())

  @@id([userId, podcastId]) 
  @@index([podcastId])
}
model SavedPodcast {
  id        String   @id @default(uuid())
  userId    String   
  podcastId String  
  
  savedAt   DateTime @default(now())

  @@unique([userId, podcastId]) 
  @@index([userId])
}